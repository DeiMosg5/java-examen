public static void sumaFilasColumnas(int[][] mat) {

    for (int i = 0; i < mat.length; i++) {
        int suma = 0;
        for (int j = 0; j < mat[0].length; j++) {
            suma += mat[i][j];
        }
        System.out.println("Fila " + i + ": " + suma);
    }

    for (int j = 0; j < mat[0].length; j++) {
        int suma = 0;
        for (int i = 0; i < mat.length; i++) {
            suma += mat[i][j];
        }
        System.out.println("Columna " + j + ": " + suma);
    }
}
