public static int determinante(int[][] mat) {
    int n = mat.length;

    if (n == 1) {
        return mat[0][0];
    }

    if (n == 2) {
        return (mat[0][0] * mat[1][1]) - (mat[0][1] * mat[1][0]);
    }

    int det = 0;

    for (int j = 0; j < n; j++) {
        det += Math.pow(-1, j) * mat[0][j] * determinante(subMatriz(mat, 0, j));
    }

    return det;
}
